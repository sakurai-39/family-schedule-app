rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /households/{householdId} {
      function isHouseholdMember() {
        return isSignedIn()
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      function requestHasValidMembers() {
        return request.resource.data.members is list
               && request.resource.data.members.size() <= 2;
      }

      function requestKeepsOnlyExistingMembers() {
        return (request.resource.data.members.size() == 1
                && request.resource.data.members[0] in resource.data.members)
               || (request.resource.data.members.size() == 2
                   && request.resource.data.members[0] in resource.data.members
                   && request.resource.data.members[1] in resource.data.members);
      }

      function requestKeepsResourceMembers() {
        return (resource.data.members.size() == 1
                && resource.data.members[0] in request.resource.data.members)
               || (resource.data.members.size() == 2
                   && resource.data.members[0] in request.resource.data.members
                   && resource.data.members[1] in request.resource.data.members);
      }

      function isExistingMemberUpdate() {
        return isHouseholdMember()
               && requestHasValidMembers()
               && request.auth.uid in request.resource.data.members
               && request.resource.data.members.size() <= resource.data.members.size()
               && requestKeepsOnlyExistingMembers();
      }

      function isInviteJoinUpdate() {
        return isSignedIn()
               && resource.data.members is list
               && requestHasValidMembers()
               && !(request.auth.uid in resource.data.members)
               && resource.data.inviteCode is string
               && resource.data.inviteCodeExpiresAt is timestamp
               && resource.data.inviteCodeExpiresAt > request.time
               && request.auth.uid in request.resource.data.members
               && request.resource.data.members.size() == resource.data.members.size() + 1
               && requestKeepsResourceMembers()
               && request.resource.data.inviteCode == null
               && request.resource.data.inviteCodeExpiresAt == null;
      }

      allow get: if isHouseholdMember();
      allow list: if isSignedIn() && resource.data.inviteCode is string;
      allow create: if isSignedIn()
                    && requestHasValidMembers()
                    && request.auth.uid in request.resource.data.members;
      allow update: if isExistingMemberUpdate() || isInviteJoinUpdate();

      match /calendar_items/{itemId} {
        function householdMembers() {
          return get(/databases/$(database)/documents/households/$(householdId)).data.members;
        }

        function isCalendarMember() {
          return isSignedIn()
                 && householdMembers() is list
                 && request.auth.uid in householdMembers();
        }

        function hasOnlyCalendarItemFields() {
          return request.resource.data.keys().hasOnly([
            'status',
            'type',
            'title',
            'assignee',
            'startAt',
            'dueAt',
            'memo',
            'isCompleted',
            'recurrence',
            'createdBy',
            'inputDurationMs',
            'createdAt',
            'updatedAt'
          ]);
        }

        function hasAllCalendarItemFields() {
          return request.resource.data.keys().hasAll([
            'status',
            'type',
            'title',
            'assignee',
            'startAt',
            'dueAt',
            'memo',
            'isCompleted',
            'recurrence',
            'createdBy',
            'inputDurationMs',
            'createdAt',
            'updatedAt'
          ]);
        }

        function isValidTitle(value) {
          return value is string && value.size() > 0 && value.size() <= 200;
        }

        function isValidMemo(value) {
          return value is string && value.size() <= 1000;
        }

        function isValidInputDuration(value) {
          return value == null
                 || (value is int && value >= 0)
                 || (value is float && value >= 0);
        }

        function isValidAssignee(value) {
          return value is string
                 && (value == 'both'
                     || value == 'whoever'
                     || value in householdMembers());
        }

        function isValidInboxData(data) {
          return data.status == 'inbox'
                 && data.type == null
                 && isValidTitle(data.title)
                 && data.assignee == null
                 && data.startAt == null
                 && data.dueAt == null
                 && isValidMemo(data.memo)
                 && data.isCompleted == false
                 && data.recurrence == null
                 && data.createdBy == request.auth.uid
                 && isValidInputDuration(data.inputDurationMs)
                 && data.createdAt == request.time
                 && data.updatedAt == request.time;
        }

        function isValidScheduledEventData(data) {
          return data.status == 'scheduled'
                 && data.type == 'event'
                 && isValidTitle(data.title)
                 && isValidAssignee(data.assignee)
                 && data.startAt is timestamp
                 && data.dueAt == null
                 && isValidMemo(data.memo)
                 && data.isCompleted is bool
                 && data.recurrence == null
                 && data.createdBy is string
                 && isValidInputDuration(data.inputDurationMs)
                 && data.createdAt is timestamp
                 && data.updatedAt == request.time;
        }

        function isValidScheduledTaskData(data) {
          return data.status == 'scheduled'
                 && data.type == 'task'
                 && isValidTitle(data.title)
                 && isValidAssignee(data.assignee)
                 && data.startAt == null
                 && (data.dueAt == null || data.dueAt is timestamp)
                 && isValidMemo(data.memo)
                 && data.isCompleted is bool
                 && data.recurrence == null
                 && data.createdBy is string
                 && isValidInputDuration(data.inputDurationMs)
                 && data.createdAt is timestamp
                 && data.updatedAt == request.time;
        }

        function isValidScheduledData(data) {
          return isValidScheduledEventData(data) || isValidScheduledTaskData(data);
        }

        function preservesImmutableFields() {
          return request.resource.data.createdBy == resource.data.createdBy
                 && request.resource.data.createdAt == resource.data.createdAt
                 && request.resource.data.inputDurationMs == resource.data.inputDurationMs;
        }

        function isValidInboxCreate() {
          return hasOnlyCalendarItemFields()
                 && hasAllCalendarItemFields()
                 && isValidInboxData(request.resource.data);
        }

        function isValidInboxToScheduledUpdate() {
          return resource.data.status == 'inbox'
                 && hasOnlyCalendarItemFields()
                 && hasAllCalendarItemFields()
                 && preservesImmutableFields()
                 && isValidScheduledData(request.resource.data);
        }

        function isValidScheduledUpdate() {
          return resource.data.status == 'scheduled'
                 && request.resource.data.status == 'scheduled'
                 && hasOnlyCalendarItemFields()
                 && hasAllCalendarItemFields()
                 && preservesImmutableFields()
                 && isValidScheduledData(request.resource.data);
        }

        allow read: if isCalendarMember();
        allow create: if isCalendarMember() && isValidInboxCreate();
        allow update: if isCalendarMember()
                      && (isValidInboxToScheduledUpdate() || isValidScheduledUpdate());
        allow delete: if isCalendarMember();
      }
    }
  }
}
