rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /households/{householdId} {
      function isHouseholdMember() {
        return isSignedIn()
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      function requestHasValidMembers() {
        return request.resource.data.members is list
               && request.resource.data.members.size() <= 2;
      }

      function requestKeepsOnlyExistingMembers() {
        return (request.resource.data.members.size() == 1
                && request.resource.data.members[0] in resource.data.members)
               || (request.resource.data.members.size() == 2
                   && request.resource.data.members[0] in resource.data.members
                   && request.resource.data.members[1] in resource.data.members);
      }

      function requestKeepsResourceMembers() {
        return (resource.data.members.size() == 1
                && resource.data.members[0] in request.resource.data.members)
               || (resource.data.members.size() == 2
                   && resource.data.members[0] in request.resource.data.members
                   && resource.data.members[1] in request.resource.data.members);
      }

      function isExistingMemberUpdate() {
        return isHouseholdMember()
               && requestHasValidMembers()
               && request.auth.uid in request.resource.data.members
               && request.resource.data.members.size() <= resource.data.members.size()
               && requestKeepsOnlyExistingMembers();
      }

      function isInviteJoinUpdate() {
        return isSignedIn()
               && resource.data.members is list
               && requestHasValidMembers()
               && !(request.auth.uid in resource.data.members)
               && resource.data.inviteCode is string
               && resource.data.inviteCodeExpiresAt is timestamp
               && resource.data.inviteCodeExpiresAt > request.time
               && request.auth.uid in request.resource.data.members
               && request.resource.data.members.size() == resource.data.members.size() + 1
               && requestKeepsResourceMembers()
               && request.resource.data.inviteCode == null
               && request.resource.data.inviteCodeExpiresAt == null;
      }

      allow get: if isHouseholdMember();
      allow list: if isSignedIn() && resource.data.inviteCode is string;
      allow create: if isSignedIn()
                    && requestHasValidMembers()
                    && request.auth.uid in request.resource.data.members;
      allow update: if isExistingMemberUpdate() || isInviteJoinUpdate();

      match /calendar_items/{itemId} {
        allow read, write: if isSignedIn()
                           && request.auth.uid in
                              get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }
  }
}
